# StockRocket environment variables
# None are required at v1 (localStorage-only, public APIs).
# These are placeholders for v1.1+.

# --- Market data ---
# VITE_FINNHUB_KEY=

# --- Supabase (v1.1) ---
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# --- Billing (v2) ---
# STRIPE_PUBLIC_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Email (v2) ---
# RESEND_API_KEY=

# --- Admin (server-side only, never shipped to client) ---
# ADMIN_SECRET=
