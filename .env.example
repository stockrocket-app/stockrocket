# StockRocket environment variables
# Set these in: Vercel project > Settings > Environment Variables
# (Production + Preview + Development)
# Never commit real values -- only this example file.

# --- Market data (server-side only, routed through /api/finnhub) ---
FINNHUB_KEY=

# --- Supabase service role (server-side only, routed through /api/codes) ---
# Service key bypasses RLS -- never ship to client
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Client-side overrides (optional; dev only) ---
# Point the client at a different API origin for local dev:
#   http://localhost:3000/?apiBase=https://stockrocket-preview.vercel.app
# In production the client uses same-origin, no override needed.
